# Quick Poll Creator - Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/quickpoll-teams

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS and QR code generation)
FRONTEND_URL=http://localhost:5173

# Admin Secret (used to create first admin account)
ADMIN_SECRET=admin_secret_key_change_this
